<!DOCTYPE html>
<html>
  <head>
    <title>Button with name</title>
  </head>
  <body>
    <button onclick="myFunction()">Click Me</button>
    <p id="demo"></p>
    
    <script>
      function myFunction(){
        const name = "Mylok";
        let age=19;
        document.getElementById("demo").innerHTML =
         "<br>Hello " + name + "!"+'<br>'+
         "<br>Age =  " + age  +'<br>' ;

      }
    </script>
  </body>
</html>
